# ==============================================================================
# AI Semantic Search Engine - Backend Environment Configurations
# ==============================================================================

# --- Application Server Configurations ---
APP_NAME="AI Semantic Search Engine"
API_VERSION="v1"
HOST="0.0.0.0"
PORT=8000
DEBUG=True

# --- Database Relational Connection ---
# Local SQLite default: sqlite+aiosqlite:///./data/app.db
# PostgreSQL template: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL="sqlite+aiosqlite:///./data/app.db"

# --- Security & Authentication (Phase 2) ---
# Generate a secure key in your terminal using: openssl rand -hex 32
JWT_SECRET_KEY="replace-with-a-secure-random-32-byte-hex-string-for-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Vector Database Configurations (FAISS vs. Qdrant) ---
# Pluggable vector store: "faiss" (local index file) or "qdrant" (cloud/local API cluster)
VECTOR_DB_TYPE="faiss"
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY=""
FAISS_INDEX_PATH="./storage/vector_store/faiss_index"

# --- LLM & Embedding Providers (Phase 4 & 6) ---
# Embedding Options: "ollama", "local" (sentence-transformers), "openai" (LM Studio), "groq", "openrouter"
# LLM Options: "groq", "openrouter", "lm-studio", "ollama"
EMBEDDING_PROVIDER="local"
LLM_PROVIDER="lm-studio"

# API Access Credentials (fill in active keys)
GROQ_API_KEY=""
OPENROUTER_API_KEY=""
NVIDIA_API_KEY=""

# Local model server URLs
OLLAMA_BASE_URL="http://localhost:11434"
LM_STUDIO_BASE_URL="http://localhost:1234/v1"

# --- Vector Index & Storage Settings (Phase 4) ---
EMBEDDING_MODEL_NAME="sentence-transformers/all-MiniLM-L6-v2"
EMBEDDING_DEVICE="cpu" # Options: "cpu", "cuda", "mps"

# --- Caching & Resilience (Phase 9) ---
REDIS_URL="redis://localhost:6379/0"
USE_REDIS_CACHE=False
